{
    "kind": "collectionType",
    "collectionName": "initiatives",
    "info": {
        "singularName": "initiative",
        "pluralName": "initiatives",
        "displayName": "Initiative",
        "description": "Project initiatives (Open Tribe Foundation, Vaka Dzidzo, FeedZim)"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "Active",
                "Completed",
                "Planned"
            ],
            "required": true,
            "default": "Active"
        },
        "shortDescription": {
            "type": "string",
            "required": true
        },
        "fullDescription": {
            "type": "richtext",
            "required": true
        },
        "images": {
            "type": "json",
            "description": "Array of Cloudflare R2 image URLs"
        },
        "imageUrl": {
            "type": "string",
            "description": "Single Cloudflare R2 image URL"
        },
        "imageTransitionTime": {
            "type": "integer",
            "default": 5000
        },
        "videoUrl": {
            "type": "string",
            "description": "Cloudflare R2 video URL"
        },
        "raised": {
            "type": "decimal"
        },
        "spent": {
            "type": "decimal"
        },
        "nextGoal": {
            "type": "decimal"
        },
        "breakdown": {
            "type": "component",
            "repeatable": true,
            "component": "initiative.breakdown-item"
        },
        "impactMetrics": {
            "type": "json",
            "description": "Impact data: studentsSupported, ageRange, hampersDelivered, locationsServed, items, events"
        }
    }
}
