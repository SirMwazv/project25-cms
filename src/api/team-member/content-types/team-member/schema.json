{
    "kind": "collectionType",
    "collectionName": "team_members",
    "info": {
        "singularName": "team-member",
        "pluralName": "team-members",
        "displayName": "Team Member",
        "description": "Founders and team members"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "occupation": {
            "type": "string",
            "required": true
        },
        "bio": {
            "type": "text"
        },
        "imageUrl": {
            "type": "string",
            "description": "Cloudflare R2 image URL"
        },
        "isFounder": {
            "type": "boolean",
            "default": true
        },
        "order": {
            "type": "integer",
            "default": 0
        }
    }
}
