{
    "kind": "singleType",
    "collectionName": "footers",
    "info": {
        "singularName": "footer",
        "pluralName": "footers",
        "displayName": "Footer",
        "description": "Footer content including company info, social links, and quick links"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "logo": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "companyName": {
            "type": "string",
            "required": true,
            "default": "Project 25"
        },
        "companyDescription": {
            "type": "richtext",
            "required": true
        },
        "trustName": {
            "type": "string",
            "required": true,
            "default": "Project 25 Trust"
        },
        "contactEmail": {
            "type": "email",
            "required": true
        },
        "socialLinks": {
            "type": "component",
            "repeatable": true,
            "component": "footer.social-link"
        },
        "quickLinks": {
            "type": "component",
            "repeatable": true,
            "component": "footer.quick-link"
        },
        "copyrightText": {
            "type": "string",
            "required": true
        },
        "developerName": {
            "type": "string",
            "required": true
        },
        "developerUrl": {
            "type": "string",
            "required": true
        }
    }
}